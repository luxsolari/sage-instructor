# OS
.DS_Store
Thumbs.db

# Editors
*.swp
*~
.vscode/
.idea/

# Claude Code — local/machine-specific, never shared across installs
.claude/settings.local.json
.claude/*.local.md
CLAUDE.local.md
.mcp.local.json

# Secrets
.env
.env.local
.env.*.local

# Sage runtime state — generated per-learner when this plugin is used
# (including local testing against this repo itself, per CONTRIBUTING.md).
# Never commit someone's actual progress/profile into the plugin repo.
.sage-progress.json
.sage-profile.md
# ...except the checked-in, synthetic fixtures the Tier 1 harness tests
# against (tests/fixtures/*/.sage-progress.json, .sage-profile.md) — those
# are committed on purpose, no real learner data.
!tests/fixtures/**/.sage-progress.json
!tests/fixtures/**/.sage-profile.md
